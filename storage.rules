rules_version = '2';

// Tulane Housing Hub — Cloud Storage security rules (sublet photos).
//
// Email verification is NOT required to upload. Any signed-in @tulane.edu
// account may upload a sublet photo. Uploads are capped at 5MB and limited to
// JPG / PNG / WebP, matching the client-side check in post-sublet.js. Owners may
// delete their own photos — files are named <uid>_<timestamp>_<rand>.<ext>, so
// the filename starts with the uploader's uid.
//
// Paste this into Firebase console → Storage → Rules → Publish.

service firebase.storage {
  match /b/{bucket}/o {

    function isTulane() {
      return request.auth != null
        && request.auth.token.email is string
        && request.auth.token.email.matches('.*@tulane[.]edu$');
    }

    // Sublet listing photos: sublets/<uid>_<timestamp>_<rand>.<ext>
    match /sublets/{file} {
      allow read: if true;
      // create/update carry a file, so we can enforce size + type here.
      allow create, update: if isTulane()
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png|webp)');
      // delete has no request.resource — allow the owner (filename starts with their uid).
      allow delete: if request.auth != null && file.matches('^' + request.auth.uid + '_.*');
    }
  }
}
